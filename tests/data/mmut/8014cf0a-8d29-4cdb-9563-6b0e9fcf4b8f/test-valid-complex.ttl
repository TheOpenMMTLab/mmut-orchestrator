@prefix MMUT: <http://frittenburger.de/ontology/mmut#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix testcomplex: <http://hpi.de/test-valid-complex#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

testcomplex:PythonScriptTransformation-a a MMUT:PythonScriptTransformation ;
    rdfs:label "a"^^xsd:string ;
    MMUT:hasOutputModel testcomplex:RDFMicroModel-Model-A1 ;
    MMUT:hasTaskDefinition testcomplex:TaskDefinition-Dummy-Transform-a ;
    rdfs:comment "Create Model A1"^^xsd:string .

testcomplex:SysMLMicroModel-Model-A2 a MMUT:SysMLMicroModel ;
    rdfs:label "Model A2"^^xsd:string ;
    MMUT:hasTaskDefinition testcomplex:TaskDefinition-Dummy-Load-Model-A2 ;
    MMUT:isInputModelOf testcomplex:PythonScriptTransformation-b ;
    rdfs:comment "An Example Model"^^xsd:string .

testcomplex:SysMLMicroModel-Model-A3 a MMUT:SysMLMicroModel ;
    rdfs:label "Model A3"^^xsd:string ;
    MMUT:hasTaskDefinition testcomplex:TaskDefinition-Dummy-Load-Model-A3 ;
    MMUT:isInputModelOf testcomplex:PythonScriptTransformation-c ;
    rdfs:comment "An Example Model"^^xsd:string .

testcomplex:ContainerProperties-Container-properties-for-Dummy-Load-Model-A1 a MMUT:ContainerProperties ;
    rdfs:label "Container properties for Dummy Load Model A1"^^xsd:string ;
    MMUT:hasCommandSequence [ a rdf:Seq ;
            rdf:_1 "echo"^^xsd:string ;
            rdf:_2 "load Model A1"^^xsd:string ] ;
    MMUT:hasEnvironment testcomplex:Environment-Environment-for-Dummy-Load-Model-A1 ;
    MMUT:image "simple-mut"^^xsd:string .

