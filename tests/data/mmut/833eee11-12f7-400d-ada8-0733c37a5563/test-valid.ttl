@prefix MMUT: <http://frittenburger.de/ontology/mmut#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix test: <http://hpi.de/test-valid#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

test:SysMLMicroModel-SysML a MMUT:SysMLMicroModel ;
    rdfs:label "SysML"^^xsd:string ;
    MMUT:hasTaskDefinition test:TaskDefinition-Dummy-Load-SysML ;
    MMUT:isInputModelOf test:PythonScriptTransformation-a ;
    rdfs:comment "SysML Papyrus Model"^^xsd:string .

test:ContainerProperties-Container-properties-for-Dummy-Load-SysML a MMUT:ContainerProperties ;
    rdfs:label "Container properties for Dummy Load SysML"^^xsd:string ;
    MMUT:hasCommandSequence [ a rdf:Seq ;
            rdf:_1 "echo"^^xsd:string ;
            rdf:_2 "load SysML"^^xsd:string ] ;
    MMUT:hasEnvironment test:Environment-Environment-for-Dummy-Load-SysML ;
    MMUT:image "simple-mut"^^xsd:string .

test:ContainerProperties-Container-properties-for-Dummy-Load-rdf a MMUT:ContainerProperties ;
    rdfs:label "Container properties for Dummy Load rdf"^^xsd:string ;
    MMUT:hasCommandSequence [ a rdf:Seq ;
            rdf:_1 "echo"^^xsd:string ;
            rdf:_2 "load rdf"^^xsd:string ] ;
    MMUT:hasEnvironment test:Environment-Environment-for-Dummy-Load-rdf ;
    MMUT:image "simple-mut"^^xsd:string .

test:ContainerProperties-Container-properties-for-Dummy-Transform-a a MMUT:ContainerProperties ;
    rdfs:label "Container properties for Dummy Transform a"^^xsd:string ;
    MMUT:hasCommandSequence [ a rdf:Seq ;
            rdf:_1 "echo"^^xsd:string ;
            rdf:_2 "transform a"^^xsd:string ] ;
    MMUT:hasEnvironment test:Environment-Environment-for-Dummy-Transform-a ;
    MMUT:image "simple-mut"^^xsd:string .

test:Environment-Environment-for-Dummy-Load-SysML a MMUT:Environment ;
    rdfs:label "Environment for Dummy Load SysML"^^xsd:string .

test:Environment-Environment-for-Dummy-Load-rdf a MMUT:Environment ;
    rdfs:label "Environment for Dummy Load rdf"^^xsd:string .

test:Environment-Environment-for-Dummy-Transform-a a MMUT:Environment ;
    rdfs:label "Environment for Dummy Transform a"^^xsd:string .

test:PythonScriptTransformation-a a MMUT:PythonScriptTransformation ;
    rdfs:label "a"^^xsd:string ;
    MMUT:hasOutputModel test:RDFMicroModel-rdf ;
    MMUT:hasTaskDefinition test:TaskDefinition-Dummy-Transform-a ;
    rdfs:comment "Create SysML to RDF Transformation"^^xsd:string .

test:RDFMicroModel-rdf a MMUT:RDFMicroModel ;
    rdfs:label "rdf"^^xsd:string ;
    MMUT:hasTaskDefinition test:TaskDefinition-Dummy-Load-rdf ;
    rdfs:comment "RDF System Model"^^xsd:string .

test:TaskDefinition-Dummy-Load-SysML a MMUT:TaskDefinition ;
    rdfs:label "Dummy Load SysML"^^xsd:string ;
    MMUT:hasContainerProperties test:ContainerProperties-Container-properties-for-Dummy-Load-SysML .

test:TaskDefinition-Dummy-Load-rdf a MMUT:TaskDefinition ;
    rdfs:label "Dummy Load rdf"^^xsd:string ;
    MMUT:hasContainerProperties test:ContainerProperties-Container-properties-for-Dummy-Load-rdf .

test:TaskDefinition-Dummy-Transform-a a MMUT:TaskDefinition ;
    rdfs:label "Dummy Transform a"^^xsd:string ;
    MMUT:hasContainerProperties test:ContainerProperties-Container-properties-for-Dummy-Transform-a .

