@prefix MMUT: <http://frittenburger.de/ontology/mmut#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix testnoproc: <http://hpi.de/test-no-process#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

testnoproc:SysMLMicroModel-SysML a MMUT:SysMLMicroModel ;
    rdfs:label "SysML"^^xsd:string ;
    MMUT:isInputModelOf testnoproc:PythonScriptTransformation-a ;
    rdfs:comment "SysML Papyrus Model"^^xsd:string .

testnoproc:PythonScriptTransformation-a a MMUT:PythonScriptTransformation ;
    rdfs:label "a"^^xsd:string ;
    MMUT:hasOutputModel testnoproc:RDFMicroModel-rdf ;
    rdfs:comment "Create SysML to RDF Transformation"^^xsd:string .

testnoproc:RDFMicroModel-rdf a MMUT:RDFMicroModel ;
    rdfs:label "rdf"^^xsd:string ;
    rdfs:comment "RDF System Model"^^xsd:string .

