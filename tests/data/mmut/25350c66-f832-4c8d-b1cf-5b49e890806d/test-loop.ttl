@prefix MMUT: <http://frittenburger.de/ontology/mmut#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix testloop: <http://hpi.de/test-loop#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

testloop:ContainerProperties-Container-properties-for-Dummy-Load-SysML a MMUT:ContainerProperties ;
    rdfs:label "Container properties for Dummy Load SysML"^^xsd:string ;
    MMUT:hasCommandSequence [ a rdf:Seq ;
            rdf:_1 "echo"^^xsd:string ;
            rdf:_2 "load SysML"^^xsd:string ] ;
    MMUT:hasEnvironment testloop:Environment-Environment-for-Dummy-Load-SysML ;
    MMUT:image "simple-mut"^^xsd:string .

testloop:ContainerProperties-Container-properties-for-Dummy-Load-rdf a MMUT:ContainerProperties ;
    rdfs:label "Container properties for Dummy Load rdf"^^xsd:string ;
    MMUT:hasCommandSequence [ a rdf:Seq ;
            rdf:_1 "echo"^^xsd:string ;
            rdf:_2 "load rdf"^^xsd:string ] ;
    MMUT:hasEnvironment testloop:Environment-Environment-for-Dummy-Load-rdf ;
    MMUT:image "simple-mut"^^xsd:string .

testloop:ContainerProperties-Container-properties-for-Dummy-Transform-a a MMUT:ContainerProperties ;
    rdfs:label "Container properties for Dummy Transform a"^^xsd:string ;
    MMUT:hasCommandSequence [ a rdf:Seq ;
            rdf:_1 "echo"^^xsd:string ;
            rdf:_2 "transform a"^^xsd:string ] ;
    MMUT:hasEnvironment testloop:Environment-Environment-for-Dummy-Transform-a ;
    MMUT:image "simple-mut"^^xsd:string .

testloop:ContainerProperties-Container-properties-for-Dummy-Transform-b a MMUT:ContainerProperties ;
    rdfs:label "Container properties for Dummy Transform b"^^xsd:string ;
    MMUT:hasCommandSequence [ a rdf:Seq ;
            rdf:_1 "echo"^^xsd:string ;
            rdf:_2 "transform b"^^xsd:string ] ;
    MMUT:hasEnvironment testloop:Environment-Environment-for-Dummy-Transform-b ;
    MMUT:image "simple-mut"^^xsd:string .

testloop:Environment-Environment-for-Dummy-Load-SysML a MMUT:Environment ;
    rdfs:label "Environment for Dummy Load SysML"^^xsd:string .

testloop:Environment-Environment-for-Dummy-Load-rdf a MMUT:Environment ;
    rdfs:label "Environment for Dummy Load rdf"^^xsd:string .

testloop:Environment-Environment-for-Dummy-Transform-a a MMUT:Environment ;
    rdfs:label "Environment for Dummy Transform a"^^xsd:string .

testloop:Environment-Environment-for-Dummy-Transform-b a MMUT:Environment ;
    rdfs:label "Environment for Dummy Transform b"^^xsd:string .

testloop:PythonScriptTransformation-a a MMUT:PythonScriptTransformation ;
    rdfs:label "a"^^xsd:string ;
    MMUT:hasOutputModel testloop:RDFMicroModel-rdf ;
    MMUT:hasTaskDefinition testloop:TaskDefinition-Dummy-Transform-a ;
    rdfs:comment "Create SysML to RDF Transformation"^^xsd:string .

testloop:PythonScriptTransformation-b a MMUT:PythonScriptTransformation ;
    rdfs:label "b"^^xsd:string ;
    MMUT:hasOutputModel testloop:SysMLMicroModel-SysML ;
    MMUT:hasTaskDefinition testloop:TaskDefinition-Dummy-Transform-b ;
    rdfs:comment "Create RDF to SysML Transformation"^^xsd:string .

testloop:RDFMicroModel-rdf a MMUT:RDFMicroModel ;
    rdfs:label "rdf"^^xsd:string ;
    MMUT:hasTaskDefinition testloop:TaskDefinition-Dummy-Load-rdf ;
    MMUT:isInputModelOf testloop:PythonScriptTransformation-b ;
    rdfs:comment "RDF System Model"^^xsd:string .

testloop:SysMLMicroModel-SysML a MMUT:SysMLMicroModel ;
    rdfs:label "SysML"^^xsd:string ;
    MMUT:hasTaskDefinition testloop:TaskDefinition-Dummy-Load-SysML ;
    MMUT:isInputModelOf testloop:PythonScriptTransformation-a ;
    rdfs:comment "SysML Papyrus Model"^^xsd:string .

testloop:TaskDefinition-Dummy-Load-SysML a MMUT:TaskDefinition ;
    rdfs:label "Dummy Load SysML"^^xsd:string ;
    MMUT:hasContainerProperties testloop:ContainerProperties-Container-properties-for-Dummy-Load-SysML .

testloop:TaskDefinition-Dummy-Load-rdf a MMUT:TaskDefinition ;
    rdfs:label "Dummy Load rdf"^^xsd:string ;
    MMUT:hasContainerProperties testloop:ContainerProperties-Container-properties-for-Dummy-Load-rdf .

testloop:TaskDefinition-Dummy-Transform-a a MMUT:TaskDefinition ;
    rdfs:label "Dummy Transform a"^^xsd:string ;
    MMUT:hasContainerProperties testloop:ContainerProperties-Container-properties-for-Dummy-Transform-a .

testloop:TaskDefinition-Dummy-Transform-b a MMUT:TaskDefinition ;
    rdfs:label "Dummy Transform b"^^xsd:string ;
    MMUT:hasContainerProperties testloop:ContainerProperties-Container-properties-for-Dummy-Transform-b .

